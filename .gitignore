# --- dependencies ---
node_modules/
app/node_modules/
backend/node_modules/

# --- secrets — never commit ---
backend/.env
backend/service-account.json
backend/tokens.json
**/GoogleService-Info.plist
**/*.keystore
**/keystore.properties

# --- release artifacts ---
*.apk
*.aab

# --- iOS native project (regenerate with `cap add ios`) ---
app/ios/

# --- Android build outputs / machine-specific (native SOURCE is committed) ---
app/android/.gradle/
app/android/build/
app/android/app/build/
app/android/captures/
app/android/.idea/
app/android/local.properties
app/android/app/release/

# --- os / editor ---
.DS_Store
*.log
.idea/
.vscode/
