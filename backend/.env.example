# Copy to .env and fill in.

# Port the push server listens on (must match BACKEND_URL in app/www/app.js)
PORT=8080

# Protect POST /send. Pass the same value as the `x-admin-key` request header.
ADMIN_KEY=change-me

# --- Firebase service-account credentials (choose ONE) ---
# Option A: path to the service-account JSON downloaded from
#   Firebase Console > Project settings > Service accounts > Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Option B: inline the whole JSON (handy for hosts like Railway/Render/Fly)
# SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"azure-standard", ...}
